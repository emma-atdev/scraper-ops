# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# OpenAI (M6 self-healing 단계에서 사용)
OPENAI_API_KEY=

# Runtime
SCRAPER_ENVIRONMENT=local
SCRAPER_ALLOWED_SITES=catch
SCRAPER_LOG_LEVEL=INFO

# M6.7 approval server (Oracle Tokyo VM에 띄우는 inbound endpoint)
# - APPROVAL_SERVER_URL: Mac이 polling으로 호출. 예: https://scraper.example.com
# - POLLER_TOKEN: VM과 Mac이 공유하는 임의 토큰 (32바이트 hex 권장: openssl rand -hex 32)
APPROVAL_SERVER_URL=
POLLER_TOKEN=
# - APPROVAL_SERVER_PORT: VM 측에서 listen할 포트 (디폴트 8765)
APPROVAL_SERVER_PORT=8765
